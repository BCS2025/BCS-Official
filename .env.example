# ============================================================
# 比創空間官網 — 環境變數範例
# ============================================================
# 實際部署時請至 Vercel Dashboard > Project Settings > Environment Variables
# 設定以下變數（.env 檔本地端開發用，切勿提交）。
# ============================================================

# ---------- Supabase ----------
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# 後端 Serverless Function 使用（.vercel 環境變數）
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---------- GAS Webhook（Email + LINE Messaging API 通知）----------
VITE_GAS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbx.../exec

# ---------- 站點 URL（LINE Pay redirectUrls 使用）----------
# 本地開發可設 http://localhost:5173；正式請設正式網址
VITE_SITE_URL=https://your-domain.vercel.app

# ---------- 銀行轉帳資訊（會顯示在感謝頁）----------
VITE_PAYMENT_BANK_NAME=中華郵政 (700)
VITE_PAYMENT_ACCOUNT=0031421-0318644
VITE_PAYMENT_ACCOUNT_NAME=黃詣

# ---------- LINE Pay（Server only，不可加 VITE_ 前綴）----------
LINE_PAY_CHANNEL_ID=1234567890
LINE_PAY_CHANNEL_SECRET=abcdef0123456789abcdef0123456789
# 沙盒測試：https://sandbox-api-pay.line.me
# 正式環境：https://api-pay.line.me
LINE_PAY_API_BASE=https://sandbox-api-pay.line.me
# 選填：僅特殊商戶類型需要
# LINE_PAY_MERCHANT_DEVICE_PROFILE_ID=xxx

# ---------- Vercel Deploy Hook（管理後台「發佈」按鈕用）----------
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/xxx

# ---------- 綠界物流 ECPay Logistics ----------
# Sandbox 測試：https://logistics-stage.ecpay.com.tw
# 正式環境：https://logistics.ecpay.com.tw
ECPAY_LOGISTICS_MERCHANT_ID=2000132
ECPAY_LOGISTICS_HASH_KEY=5294y06JbISpM5x9
ECPAY_LOGISTICS_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_LOGISTICS_BASE_URL=https://logistics-stage.ecpay.com.tw

# 寄件人資訊（必填 cellPhone，其餘有預設值）
ECPAY_LOGISTICS_SENDER_NAME=比創空間
ECPAY_LOGISTICS_SENDER_CELLPHONE=0900000000
ECPAY_LOGISTICS_SENDER_PHONE=
ECPAY_LOGISTICS_SENDER_ZIP=710
ECPAY_LOGISTICS_SENDER_ADDRESS=臺南市永康區六合里新興街34巷2之2號

# Callback URL（選填）
# 不設則自動由 request header (host) 推導，preview 部署會自動跟著 preview URL 走
# 顯式設定可覆寫（例如 webhook 要永遠打 production，或共用集中接收）
# VITE_LOGISTICS_REPLY_URL=https://bcs.tw/api/logistics/select-store-callback
# VITE_LOGISTICS_STATUS_WEBHOOK_URL=https://bcs.tw/api/logistics/status-webhook
